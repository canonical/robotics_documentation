{
    "plugins": {
        "selectively_enable_rules": true,
        "heading-increment": {
            "enabled": true
        },
        "heading-style": {
            "enabled": true,
            "style": "atx"
        },
        "list-indent": {
            "enabled": true
        },
        "no-trailing-spaces": {
            "enabled": true
        },
        "no-reversed-links": {
            "enabled": true
        },
        "no-multiple-blanks": {
            "enabled": true
        },
        "line-length": {
            "enabled": true,
            "line_length": 85,  # Diverged from upstream: custom line length limit
            "code_blocks": false
        },
        "commands-show-output": {
            "enabled": true
        },
        "no-missing-space-atx": {
            "enabled": true
        },
        "no-multiple-space-atx": {
            "enabled": true
        },
        "blanks-around-headings": {
            "enabled": true
        },
        "heading-start-left": {
            "enabled": true
        },
        "no-duplicate-heading": {
            "enabled": false
        },
        "single-title": {
            "enabled": true
        },
        "no-trailing-punctuation": {
            "enabled": true,
            "punctuation": ".,;。，；"
        },
        "blanks-around-fences": {
            "enabled": true,
            "list_items": false
        },
        "blanks-around-lists": {
            "enabled": true
        },
        "no-inline-html": {
            "enabled": true,
            "allowed_elements": ["br"]  # Diverged from upstream: allow <br> elements
        },
        "hr-style": {
            "enabled": true
        },
        "no-empty-links": {
            "enabled": true
        },
        "no-alt-text": {
            "enabled": true
        }
    },
    "extensions": {
        "front-matter" : {
            "enabled" : true
        }
    }
}
